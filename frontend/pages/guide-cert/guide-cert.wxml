<view class="guide-cert-container">
  <!-- 子导航 -->
  <view class="sub-nav">
    <scroll-view scroll-x="{{true}}" class="sub-nav-scroll">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="sub-nav-item {{currentTab === item.key ? 'active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="switchTab"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <!-- 课程分类 -->
  <view class="category-container">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{selectedCategory === item.key ? 'active' : ''}}"
        data-category="{{item.key}}"
        bindtap="selectCategory"
      >{{item.name}}</view>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="course-list">
    <view
      class="course-item card-shadow"
      wx:for="{{courseList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onCourseTap"
    >
      <view class="course-content">
        <image src="{{item.image}}" class="course-image" mode="aspectFill"></image>
        <view class="course-info">
          <text class="course-name">{{item.name}}</text>
          <text class="course-desc">{{item.desc}}</text>
          <view class="course-footer">
            <text class="course-price">{{item.price}}</text>
            <text class="course-rating">{{item.rating}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{courseList.length === 0}}">该分类下暂无课程</view>
  </view>
</view>
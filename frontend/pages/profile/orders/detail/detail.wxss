/* 订单详情页面样式 */
.order-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 订单状态 */
.order-status-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background-color: #fff;
  margin-bottom: 16rpx;
}

.status-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.status-icon.unpaid {
  color: #ff4d4f;
}

.status-icon.paid {
  color: #1677ff;
}

.status-icon.completed {
  color: #52c41a;
}

.status-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #262626;
}

/* 订单信息 */
.order-info-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.info-value {
  font-size: 24rpx;
  color: #262626;
}

/* 收货信息 */
.shipping-info-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
}

.shipping-info {
  padding-left: 48rpx;
}

.recipient {
  font-size: 24rpx;
  color: #262626;
  margin-bottom: 8rpx;
  display: block;
}

.address {
  font-size: 24rpx;
  color: #595959;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}

.contact {
  font-size: 24rpx;
  color: #595959;
  display: block;
}

/* 商品信息 */
.products-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.product-list {
  padding-left: 48rpx;
}

.product-item {
  display: flex;
  margin-bottom: 24rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 24rpx;
  color: #262626;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-price-quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.product-quantity {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* 价格信息 */
.price-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 100rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-item:last-child {
  margin-bottom: 0;
}

.price-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.price-value {
  font-size: 24rpx;
  color: #262626;
}

.price-item.total {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-top: 16rpx;
}

.price-item.total .price-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
}

.price-item.total .price-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #ff4d4f;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-primary {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #fff;
  background-color: #1677ff;
  border-radius: 8rpx;
  border: none;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #fff;
  background-color: #52c41a;
  border-radius: 8rpx;
  border: none;
}

.btn-tertiary {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #1677ff;
  background-color: transparent;
  border-radius: 8rpx;
  border: 1rpx solid #1677ff;
}

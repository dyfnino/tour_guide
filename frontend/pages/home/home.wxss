/* 首页样式 */
.home-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #fff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #262626;
}

/* 轮播图 */
.carousel-container {
  position: relative;
  height: 320rpx;
  margin-bottom: 16rpx;
}

.carousel-image {
  width: 100%;
  height: 100%;
}

.carousel-text {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 功能入口 */
.function-entry {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background-color: #fff;
  margin-bottom: 16rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.entry-icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 16rpx;
}

.entry-icon-primary {
  background-color: rgba(22, 119, 255, 0.1);
}

.entry-icon-secondary {
  background-color: rgba(255, 125, 0, 0.1);
}

.entry-icon-success {
  background-color: rgba(82, 196, 26, 0.1);
}

.entry-icon-warning {
  background-color: rgba(250, 173, 20, 0.1);
}

.icon-text {
  font-size: 48rpx;
}

.entry-title {
  font-size: 24rpx;
  color: #595959;
}

/* 推荐课程 */
.course-section {
  background-color: #fff;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #262626;
}

.section-more {
  font-size: 24rpx;
  color: #1677ff;
}

.arrow {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.course-list {
  display: flex;
  justify-content: space-between;
}

.course-item {
  width: 48%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #fff;
}

.course-image {
  width: 100%;
  height: 224rpx;
}

.course-info {
  padding: 16rpx;
}

.course-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-price {
  font-size: 20rpx;
  font-weight: bold;
}

.course-students {
  font-size: 20rpx;
  color: #8c8c8c;
}

/* 热门特产 */
.specialty-section {
  background-color: #fff;
  padding: 16rpx;
  margin-bottom: 100rpx;
}

.specialty-list {
  display: flex;
  justify-content: space-between;
}

.specialty-item {
  width: 48%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #fff;
}

.specialty-image {
  width: 100%;
  height: 224rpx;
}

.specialty-info {
  padding: 16rpx;
}

.specialty-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.specialty-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.specialty-price {
  font-size: 24rpx;
  font-weight: bold;
}

.specialty-tag {
  font-size: 20rpx;
  color: #8c8c8c;
}

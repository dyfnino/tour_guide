<view class="course-page" wx:if="{{course}}">
  <!-- 视频播放区 -->
  <block wx:if="{{isPlaying && mediaType === 'video'}}">
    <video
      id="courseVideo"
      class="player"
      src="{{mediaUrl}}"
      controls="{{true}}"
      autoplay="{{true}}"
      show-fullscreen-btn="{{true}}"
      object-fit="contain"
      bindtimeupdate="onVideoTimeUpdate"
      bindended="onVideoEnded"
      binderror="onVideoError"
    ></video>
  </block>

  <!-- 音频播放区 -->
  <block wx:elif="{{isPlaying && mediaType === 'audio'}}">
    <view class="audio-player">
      <image class="audio-cover" src="{{course.image}}" mode="aspectFill"></image>
      <text class="audio-title">{{course.name}}</text>
      <view class="audio-btn" bindtap="onAudioToggle">
        <text>{{audioPlaying ? '⏸ 暂停' : '▶ 播放'}}</text>
      </view>
    </view>
  </block>

  <!-- 默认封面 -->
  <image wx:else class="cover" src="{{course.image}}" mode="aspectFill"></image>

  <view class="info">
    <text class="name">{{course.name}}</text>
    <text class="desc">{{course.desc}}</text>
    <view class="meta">
      <text class="price">{{enrolled ? '已购买' : course.price}}</text>
      <text class="rating">{{course.category}}</text>
    </view>
    <text class="lecturer">主讲：{{course.lecturer}}</text>

    <!-- 学习进度（仅已购显示） -->
    <view class="progress-wrap" wx:if="{{enrolled}}">
      <view class="progress-bar"><view class="progress-inner" style="width: {{progress}}%"></view></view>
      <text class="progress-text">已学 {{progress}}%</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">课程介绍</text>
    <text class="section-text">本课程系统讲解{{course.name}}相关知识，帮助学员快速掌握考点与实操技巧，附配套习题与答疑服务。</text>
  </view>
  <view class="footer">
    <button class="enroll-btn" bindtap="onEnroll">{{enrolled ? '立即学习' : '立即购买'}}</button>
  </view>
</view>
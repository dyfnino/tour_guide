.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  background-color: #f5f5f5;
}

.logo-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  background-color: #07c160;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  line-height: 1.5;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.login-container {
  width: 100%;
  max-width: 500rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.login-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 60rpx;
  text-align: center;
}

.wechat-login-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #07c160;
  margin-bottom: 40rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.wechat-login-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.login-tip {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.agreement-link {
  color: #07c160;
  text-decoration: none;
}

/* 适配不同屏幕尺寸 */
@media (max-width: 375px) {
  .login-container {
    padding: 40rpx 30rpx;
  }

  .login-title {
    font-size: 28rpx;
  }

  .login-desc {
    font-size: 22rpx;
  }
}

<view class="specialty-container">
  <!-- 分类导航 -->
  <view class="category-nav">
    <scroll-view scroll-x="{{true}}" class="category-scroll">
      <view class="category-item active" bindtap="selectCategory" data-category="all">全部</view>
      <view class="category-item" bindtap="selectCategory" data-category="food">特色食品</view>
      <view class="category-item" bindtap="selectCategory" data-category="cultural">文创产品</view>
      <view class="category-item" bindtap="selectCategory" data-category="craft">手工艺品</view>
      <view class="category-item" bindtap="selectCategory" data-category="local">地方特产</view>
    </scroll-view>
  </view>

  <!-- 产品列表 -->
  <view class="product-list">
    <view class="product-item card-shadow" wx:for="{{productList}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
      <image src="{{item.image}}" class="product-image" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-footer">
          <text class="product-price">{{item.price}}</text>
          <view class="add-to-cart" bindtap="onAddToCart" data-id="{{item.id}}">
            <text class="cart-icon">+</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
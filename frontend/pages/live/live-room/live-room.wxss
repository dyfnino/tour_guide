.room-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.video-wrap {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #000;
}
.video {
  width: 100%;
  height: 100%;
}
.live-flag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: rgba(255, 77, 79, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 8rpx;
}

.info-bar {
  background: #fff;
  padding: 24rpx;
}
.title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #262626;
}
.lecturer {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

.chat {
  flex: 1;
  background: #fff;
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
}
.msg {
  padding: 12rpx 0;
  font-size: 26rpx;
  line-height: 1.6;
}
.msg-user {
  color: #1677ff;
  margin-right: 8rpx;
}
.msg-content {
  color: #262626;
}

.action-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}
.msg-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}
.action-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #ff4d4f;
}
.action-btn .count {
  font-size: 22rpx;
  color: #595959;
  margin-left: 4rpx;
}
.send-btn {
  background: #1677ff;
  color: #fff;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
}

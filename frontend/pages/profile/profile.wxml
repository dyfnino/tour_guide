<view class="profile-container">
  <!-- 用户信息 -->
  <view class="user-info" bindtap="onLoginTap">
    <image src="{{userInfo.avatarUrl}}" class="avatar"></image>
    <view class="user-details">
      <text class="user-name">{{userInfo.nickName}}</text>
      <text class="user-action">{{userInfo.action}}</text>
    </view>
    <text class="user-arrow">›</text>
  </view>

  <!-- 主功能 -->
  <view class="function-section">
    <view class="function-item" bindtap="onMyCoursesTap">
      <view class="function-icon function-icon-primary"><text class="icon-text">📚</text></view>
      <text class="function-name">我的课程</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onMyOrdersTap">
      <view class="function-icon function-icon-secondary"><text class="icon-text">🛍️</text></view>
      <text class="function-name">我的订单</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onWalletTap">
      <view class="function-icon function-icon-warning"><text class="icon-text">💰</text></view>
      <text class="function-name">我的钱包</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onDistributionTap">
      <view class="function-icon function-icon-success"><text class="icon-text">📤</text></view>
      <text class="function-name">分销中心</text>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onSettingsTap">
      <view class="function-icon function-icon-gray"><text class="icon-text">⚙️</text></view>
      <text class="function-name">设置</text>
      <text class="function-arrow">›</text>
    </view>
  </view>

  <!-- 帮助中心 -->
  <view class="help-section">
    <view class="help-header">
      <text class="help-title">帮助中心</text>
    </view>
    <view class="help-content">
      <view class="help-item" bindtap="onCustomerServiceTap">
        <text class="help-icon">🎧</text>
        <text class="help-name">在线客服</text>
      </view>
      <view class="help-item" bindtap="onFAQTap">
        <text class="help-icon">❓</text>
        <text class="help-name">常见问题</text>
      </view>
      <view class="help-item" bindtap="onContactUsTap">
        <text class="help-icon">📞</text>
        <text class="help-name">联系我们</text>
      </view>
    </view>
  </view>
</view>
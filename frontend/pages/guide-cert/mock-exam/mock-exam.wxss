.exam-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 开始页 */
.start-page {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}
.banner {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 32rpx;
}
.info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  font-size: 26rpx;
  color: #595959;
  margin-bottom: 48rpx;
}

.primary-btn {
  background: #1677ff;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.ghost-btn {
  background: #f0f0f0;
  color: #595959;
  font-size: 30rpx;
  border-radius: 8rpx;
}

/* 答题页 */
.exam-page {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.exam-header {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.exam-header .progress {
  flex: 1;
  font-size: 28rpx;
  color: #595959;
}
.exam-header .countdown {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-right: 24rpx;
}
.exam-header .submit-btn {
  font-size: 28rpx;
  color: #1677ff;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}
.q-title {
  display: block;
  font-size: 30rpx;
  color: #262626;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.option.selected {
  border-color: #1677ff;
  background: #e6f0ff;
}

.opt-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  text-align: center;
  line-height: 48rpx;
  font-size: 24rpx;
  color: #595959;
  margin-right: 24rpx;
  border: 1rpx solid #d9d9d9;
}
.opt-text {
  flex: 1;
  font-size: 28rpx;
}

.card-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.card-cell {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 8rpx;
  background: #f0f0f0;
  font-size: 24rpx;
  color: #595959;
}
.card-cell.done {
  background: #e6f0ff;
  color: #1677ff;
}
.card-cell.cur {
  background: #1677ff;
  color: #fff;
}

.exam-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  display: flex;
  gap: 16rpx;
}
.exam-footer button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
}

/* 结果页 */
.result-page {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #1677ff;
  color: #fff;
  font-size: 80rpx;
  font-weight: bold;
  text-align: center;
  line-height: 240rpx;
  margin-bottom: 32rpx;
}
.score-tip {
  font-size: 32rpx;
  color: #262626;
  margin-bottom: 12rpx;
}
.score-detail {
  font-size: 26rpx;
  color: #595959;
  margin-bottom: 48rpx;
}

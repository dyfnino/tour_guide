.ph {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.emoji {
  font-size: 120rpx;
}
.title {
  font-size: 36rpx;
  color: #262626;
  margin-top: 32rpx;
  font-weight: bold;
}
.tip {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 16rpx;
}

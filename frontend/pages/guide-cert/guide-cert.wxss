/* 导游考证页面样式 */
.guide-cert-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 子导航 */
.sub-nav {
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.sub-nav-scroll {
  white-space: nowrap;
}

.sub-nav-item {
  display: inline-block;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #595959;
  position: relative;
}

.sub-nav-item.active {
  color: #1677ff;
  font-weight: 500;
}

.sub-nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #1677ff;
  border-radius: 2rpx;
}

/* 课程分类 */
.category-container {
  background-color: #fff;
  padding: 24rpx 16rpx;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  background-color: #f5f5f5;
  font-size: 24rpx;
  color: #595959;
}

.category-item.active {
  background-color: #1677ff;
  color: #fff;
}

/* 课程列表 */
.course-list {
  padding: 0 16rpx;
  margin-bottom: 100rpx;
}

.course-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.course-content {
  display: flex;
  padding: 24rpx;
}

.course-image {
  width: 192rpx;
  height: 128rpx;
  border-radius: 8rpx;
}

.course-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-desc {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
}

.course-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #1677ff;
}

.course-rating {
  font-size: 24rpx;
  color: #8c8c8c;
}
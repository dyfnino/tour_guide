.course-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.cover {
  width: 100%;
  height: 400rpx;
}

.player {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.audio-player {
  width: 100%;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.audio-cover {
  width: 280rpx;
  height: 280rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}
.audio-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}
.audio-btn {
  margin-top: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #1677ff;
  padding: 16rpx 64rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.info {
  background: #fff;
  padding: 32rpx;
}
.name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 16rpx;
}
.desc {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
}
.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}
.rating {
  font-size: 24rpx;
  color: #8c8c8c;
}
.lecturer {
  font-size: 26rpx;
  color: #595959;
}

.progress-wrap {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.progress-bar {
  flex: 1;
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #1677ff, #4096ff);
  transition: width 0.3s ease;
}
.progress-text {
  font-size: 24rpx;
  color: #1677ff;
  min-width: 120rpx;
  text-align: right;
}

.section {
  background: #fff;
  margin-top: 24rpx;
  padding: 32rpx;
}
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 16rpx;
}
.section-text {
  display: block;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.7;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.enroll-btn {
  background: #1677ff;
  color: #fff;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
}

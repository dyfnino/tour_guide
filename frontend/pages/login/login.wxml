<view class="container">
  <view class="logo-container">
    <view class="logo-placeholder">
      <text class="logo-text">导游\n服务</text>
    </view>
    <text class="app-name">导游服务平台</text>
  </view>
  
  <view class="login-container">
    <text class="login-title">欢迎使用导游服务平台</text>
    <text class="login-desc">请使用微信登录，享受更多服务</text>
    
    <button 
      class="wechat-login-btn" 
      bindtap="wechatLogin"
      type="primary"
      size="default"
      plain="false"
      form-type="button"
     style="position: relative; left: 0rpx; top: -1rpx">
      <view class="wechat-icon-text">微</view>
      <text class="wechat-login-text">微信登录</text>
    </button>
    
    <view class="login-tip">
      <text>登录即表示您同意</text>
      <navigator url="/pages/agreement/agreement" class="agreement-link">《用户协议》</navigator>
      <text>和</text>
      <navigator url="/pages/privacy/privacy" class="agreement-link">《隐私政策》</navigator>
    </view>
  </view>
</view>
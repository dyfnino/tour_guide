# 数据库连接信息（MySQL）
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/guide?charset=utf8mb4

# 应用配置
APP_NAME=导游服务平台
APP_VERSION=1.0.0
DEBUG=True

# CORS配置（小程序端开发时不限域名）
ALLOWED_ORIGINS=*

# 微信小程序（未配置时走开发态登录降级）
WECHAT_APPID=
WECHAT_SECRET=
SECRET_KEY=guide-platform-dev-secret-key

# ---- 微信支付 v3（小程序 JSAPI） ----
# WX_PAY_MOCK=1 时跳过真实支付，仅用于本地联调；置 0 走真实通道
WX_PAY_MOCK=1
WX_PAY_APPID=aaaaaaaaaaaa
WX_PAY_MCHID=mmmmmmmmmmmmm
WX_PAY_APIV3_KEY=uuuuuuuuuuuuuuuu
WX_PAY_CERT_SERIAL_NO=8888888888888
# 商户私钥文件路径（apiclient_key.pem），相对 backend 目录或绝对路径
WX_PAY_PRIVATE_KEY_PATH=certs/apiclient_key.pem
# 微信平台证书目录（用于回调验签）
WX_PAY_CERT_DIR=certs/wx_platform
# 回调地址（外网可达，必须 https）
WX_PAY_NOTIFY_URL=kkkkkkkk

# ---- 阿里云 DashScope (Qwen 多模态) ----
# 在 https://bailian.console.aliyun.com/?apiKey=1 申请 API Key 后填入
DASHSCOPE_API_KEY=
# 强制使用 mock（1=mock，0=按是否有 API Key 自动判断）
QWEN_MOCK=0
# 模型可选，默认即可
QWEN_TEXT_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-max
QWEN_AUDIO_MODEL=qwen-audio-turbo
QWEN_OMNI_MODEL=qwen-omni-turbo
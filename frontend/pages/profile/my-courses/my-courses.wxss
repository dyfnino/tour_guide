.mc-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 16rpx;
}
.empty {
  text-align: center;
  color: #bfbfbf;
  padding: 80rpx 0;
}

.mc-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.mc-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.mc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.mc-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
}
.mc-desc {
  font-size: 24rpx;
  color: #8c8c8c;
}
.mc-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mc-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}
.mc-bar-inner {
  height: 100%;
  background: #1677ff;
}
.mc-progress-text {
  font-size: 22rpx;
  color: #1677ff;
}

/* AI测评页面样式 */
.ai-test-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* AI测评介绍 */
.ai-intro {
  margin-bottom: 16rpx;
}

.ai-banner {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.ai-image {
  width: 100%;
  height: 100%;
}

.ai-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 32rpx 24rpx;
  color: #fff;
}

.ai-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.ai-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.ai-description {
  background-color: #fff;
  padding: 24rpx;
}

.description-text {
  font-size: 24rpx;
  color: #595959;
  line-height: 1.5;
}

/* 测评类型 */
.test-types {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.test-header {
  margin-bottom: 24rpx;
}

.test-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #262626;
}

.test-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.test-item {
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.test-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.test-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 8rpx;
  display: block;
}

.test-desc {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* AI对话区域 */
.chat-section {
  background-color: #fff;
  margin-bottom: 100rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.chat-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #262626;
}

.chat-status {
  font-size: 24rpx;
  color: #52c41a;
}

.chat-container {
  padding: 24rpx;
  min-height: 400rpx;
  max-height: 600rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.message {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.message-ai {
  justify-content: flex-start;
}

.message-user {
  justify-content: flex-start;
}

.message-avatar {
  font-size: 40rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
  max-width: 70%;
}

.message-text {
  font-size: 24rpx;
  color: #262626;
  line-height: 1.5;
  padding: 16rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  display: block;
}

.message-ai .message-text {
  background-color: #e6f7ff;
}

.message-user .message-text {
  background-color: #1677ff;
  color: #fff;
}

.chat-input {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.input-field {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background-color: #f5f5f5;
  font-size: 24rpx;
  color: #262626;
}

.send-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1677ff;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.send-button::after {
  border: none;
}

/* ===== 多模态扩展样式 ===== */

.tool-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 50%;
  background: #f5f5f5;
  margin-right: 8rpx;
}
.tool-icon.recording {
  background: #ff4d4f;
  color: #fff;
}

/* 待发素材 */
.pending-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
}
.pending-img {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}
.pending-img image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.pending-audio {
  position: relative;
  height: 60rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  background: #e6f7ff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #1677ff;
}
.remove {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 消息中的图片/语音 */
.message-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.message-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}
.message-audio {
  margin-top: 8rpx;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #1677ff;
  display: inline-block;
}
.message-model {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #bfbfbf;
}

/* 测评作答区 */
.eval-section {
  background: #fff;
  margin: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.eval-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.eval-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #262626;
}
.eval-back {
  font-size: 24rpx;
  color: #1677ff;
}
.eval-topic {
  background: #fafafa;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.topic-label {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 6rpx;
}
.topic-text {
  display: block;
  font-size: 26rpx;
  color: #262626;
  line-height: 1.6;
}
.eval-input {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #262626;
  box-sizing: border-box;
  background: #fff;
}
.eval-tools {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
.tool-btn {
  flex: 1;
  height: 72rpx;
  font-size: 24rpx;
  background: #f5f5f5;
  color: #262626;
  border-radius: 36rpx;
  padding: 0 16rpx;
  line-height: 72rpx;
}
.tool-btn.recording {
  background: #ff4d4f;
  color: #fff;
}
.tool-btn.primary {
  background: #1677ff;
  color: #fff;
}

/* 测评结果 */
.eval-result {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0f5ff, #e6f7ff);
  border-radius: 16rpx;
}
.score-row {
  text-align: center;
  margin-bottom: 16rpx;
}
.score {
  font-size: 80rpx;
  font-weight: bold;
  color: #1677ff;
}
.score-suffix {
  font-size: 28rpx;
  color: #8c8c8c;
}
.result-block {
  margin-top: 16rpx;
}
.result-label {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 8rpx;
}
.result-text {
  display: block;
  font-size: 26rpx;
  color: #262626;
  line-height: 1.7;
  white-space: pre-wrap;
}
.model-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #bfbfbf;
  text-align: right;
}

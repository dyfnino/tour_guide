<view class="orders-container">
  <!-- 订单状态切换 -->
  <view class="status-tabs">
    <view class="tab-item {{currentStatus === 'all' ? 'active' : ''}}" bindtap="switchStatus" data-status="all">全部</view>
    <view class="tab-item {{currentStatus === 'unpaid' ? 'active' : ''}}" bindtap="switchStatus" data-status="unpaid">未支付</view>
    <view class="tab-item {{currentStatus === 'paid' ? 'active' : ''}}" bindtap="switchStatus" data-status="paid">已支付</view>
    <view class="tab-item {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="switchStatus" data-status="completed">已完成</view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item card-shadow" wx:for="{{orders}}" wx:key="id" bindtap="viewOrderDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-id">订单号: {{item.orderNo || item.id}}</text>
        <text class="order-type-tag" wx:if="{{item.isCourse}}">课程</text>
        <text class="order-status {{item.status}}">{{item.status === 'unpaid' ? '未支付' : (item.status === 'paid' ? '已支付' : '已完成')}}</text>
      </view>
      <view class="order-products">
        <view class="product-item" wx:for="{{item.products}}" wx:key="productId" wx:for-item="product">
          <image src="{{product.image}}" class="product-image" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{product.name}}</text>
            <view class="product-price-quantity">
              <text class="product-price">{{product.price}}</text>
              <text class="product-quantity">x{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">合计: {{item.totalPrice}}</text>
        <view class="order-actions">
          <button wx:if="{{item.status === 'unpaid'}}" class="btn-primary" catchtap="payOrder" data-id="{{item.id}}">去支付</button>
          <button wx:if="{{item.status === 'paid' && !item.isCourse}}" class="btn-secondary" catchtap="confirmReceipt" data-id="{{item.id}}">确认收货</button>
          <button wx:if="{{item.status === 'paid' && item.isCourse}}" class="btn-secondary" catchtap="goToStudy">开始学习</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{orders.length === 0}}" class="empty-state">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
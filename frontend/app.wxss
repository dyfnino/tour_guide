/* 全局样式 */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', 'Arial', 'sans-serif';
  background-color: #f5f5f5;
  color: #262626;
}

/* 通用样式类 */
.container {
  padding: 0 16rpx;
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 按钮样式 */
.btn-primary {
  background-color: #1677ff;
  color: white;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  text-align: center;
}

.btn-secondary {
  background-color: #ff7d00;
  color: white;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  text-align: center;
}

/* 文本样式 */
.text-primary {
  color: #1677ff;
}

.text-secondary {
  color: #ff7d00;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #ff4d4f;
}

.text-gray {
  color: #8c8c8c;
}

/* 间距 */
.mt-1 {
  margin-top: 8rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-3 {
  margin-top: 24rpx;
}

.mb-1 {
  margin-bottom: 8rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-3 {
  margin-bottom: 24rpx;
}

/* 轮播图样式 */
.carousel {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.carousel-item {
  display: none;
  height: 100%;
  width: 100%;
}

.carousel-item.active {
  display: block;
}

.carousel-dot {
  width: 16rpx;
  height: 4rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 2rpx;
  margin: 0 6rpx;
  transition: all 0.3s;
}

.carousel-dot.active {
  background-color: #1677ff;
  width: 32rpx;
}
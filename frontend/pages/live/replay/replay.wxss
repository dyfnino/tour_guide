.replay-page {
  min-height: 100vh;
  background: #f5f5f5;
}
.player {
  width: 100%;
  height: 420rpx;
  background: #000;
}

.info {
  background: #fff;
  padding: 24rpx;
}
.name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 12rpx;
}
.meta {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
}

.desc-card {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}
.desc-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 16rpx;
}
.desc-text {
  display: block;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.7;
}

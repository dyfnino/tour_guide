/* 直播课堂页面样式 */
.live-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 直播入口 */
.live-entry {
  margin-bottom: 16rpx;
}

.live-banner {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.live-image {
  width: 100%;
  height: 100%;
}

.live-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 32rpx 24rpx;
  color: #fff;
}

.live-status {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  margin-right: 8rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}

.live-text {
  font-size: 24rpx;
}

.live-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.live-subtitle {
  font-size: 20rpx;
  opacity: 0.8;
  display: block;
}

/* 回放合集 */
.replay-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 100rpx;
}

.replay-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.replay-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #262626;
}

.replay-more {
  font-size: 24rpx;
  color: #1677ff;
}

.arrow {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.replay-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.replay-item {
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #fff;
}

.replay-image {
  width: 100%;
  height: 200rpx;
}

.replay-info {
  padding: 24rpx;
}

.replay-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.replay-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.replay-lecturer {
  font-size: 24rpx;
  color: #8c8c8c;
}

.replay-views {
  font-size: 24rpx;
  color: #8c8c8c;
}